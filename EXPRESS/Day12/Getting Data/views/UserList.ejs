<html>
  <body>
    <table border="1" align="center">
      <tr>
        <th>ID</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Date of Birth</th>
        <th>Gender</th>
      </tr>

      <% for(let i=0;i<data.length;i++){%>
        <tr>
          <td><%=data[i].id%></td>
          <td><%=data[i].fname%></td>
          <td><%=data[i].lname%></td>
          <td><%=data[i].dob%></td>
          <td><%=data[i].gender%></td>
        </tr>

      <%}%>
    </table>
  </body>
</html>